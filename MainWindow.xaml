<Window x:Class="_7._2_Aleksyuk_Khachatryan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_7._2_Aleksyuk_Khachatryan"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Text="1. Исходный текст: " FontSize="24" FontWeight="Bold" Margin="5" Foreground="DarkBlue" TextWrapping="Wrap"/>
            <Border BorderBrush="DarkOrange" BorderThickness="1" CornerRadius="5" Margin="5" Padding="5" Width="555">
                <TextBox x:Name="InputTextBox" FontSize="16"  Grid.Row="1" Foreground="DarkBlue" TextWrapping="Wrap" ToolTip="Введите текст для шифрования" BorderThickness="0"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Text="2. Зашифрованный текст (Числа):" FontSize="24" FontWeight="Bold" Margin="5" Foreground="DarkBlue"/>
            <Border BorderBrush="DarkOrange" BorderThickness="1" CornerRadius="5" Margin="5" Padding="5" Width="555">
                <TextBox x:Name="CipherTextBox" FontSize="16" Foreground="DarkBlue" AcceptsReturn="True" TextWrapping="Wrap" ToolTip="Здесь появятся числа после шифрования" IsReadOnly="True" BorderThickness="0"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Text="3. Расшифрованный текст (После дешифровки):" FontSize="24" FontWeight="Bold" Margin="5" Foreground="DarkBlue"/>
            <Border BorderBrush="DarkOrange" BorderThickness="1" CornerRadius="5" Margin="5" Padding="5" Width="555" HorizontalAlignment="Left">
                <TextBox x:Name="DecryptedTextBox" FontSize="16" Foreground="DarkBlue"  AcceptsReturn="True" TextWrapping="Wrap" ToolTip="Здесь появится восстановленный текст" IsReadOnly="True" BorderThickness="0"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="3" VerticalAlignment="Center">
            <TextBlock x:Name="KeyStatusLabel" Text="Ключи не сгенерированы" FontSize="16" Foreground="Red" HorizontalAlignment="Center" Margin="5"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border BorderBrush="DarkOrange" BorderThickness="1" CornerRadius="5" Margin="5" Padding="5" Background="DarkOrange">
                    <Button Content="Генерация ключей" Click="GenerateKeys_Click" Margin="5" Background="DarkOrange" BorderThickness="0" Foreground="White" FontSize="16"/>
                </Border>

                <Border BorderBrush="DarkOrange" BorderThickness="1" CornerRadius="5" Margin="5" Padding="5" Background="DarkOrange">
                    <Button Content="Зашифровать" Click="Encrypt_Click" Margin="5" Background="DarkOrange" BorderThickness="0" Foreground="White" FontSize="16"/>
                </Border>

                <Border BorderBrush="DarkOrange" BorderThickness="1" CornerRadius="5" Margin="5" Padding="5" Background="DarkOrange">
                    <Button Content="Дешифровать" Click="Decrypt_Click" Margin="5" Background="DarkOrange" BorderThickness="0" Foreground="White" FontSize="16"/>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
